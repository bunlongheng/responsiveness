{
    "name": "responsiveness",
    "version": "0.1.0",
    "private": false,
    "license": "MIT",
    "description": "Paste any URL and preview it live across real device frames - iPhone, iPad, Android, Desktop, Watch, TV.",
    "scripts": {
        "dev": "next dev --port 3021",
        "build": "next build",
        "start": "next start",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "audit:prod": "npm audit --omit=dev --audit-level=high",
        "prepare": "husky"
    },
    "dependencies": {
        "next": "^16.2.10",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.6",
        "@next/eslint-plugin-next": "^16.2.10",
        "@playwright/test": "^1.61.1",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@typescript-eslint/parser": "^8.64.0",
        "eslint": "^9.39.5",
        "eslint-config-next": "^16.2.10",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "husky": "^9.1.7",
        "prettier": "^3.4.2",
        "typescript": "^5",
        "vitest": "^4.1.10"
    },
    "overrides": {
        "postcss": "^8.5.10"
    }
}
